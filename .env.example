# Day Trader Pro — environment configuration
# Copy this file to .env in the repo root. All keys are OPTIONAL.
# With no keys at all, the app runs in clearly-labeled SIMULATED mode.

# ------------------------------------------------------------------
# Alpaca (free "Basic" plan) — US real-time data, IEX exchange only.
# Sign up: https://alpaca.markets/ -> dashboard -> API Keys.
# The free feed covers ~2% of US market volume (IEX), so volume-based
# metrics are partial. Paper-trading keys work for market data.
# ------------------------------------------------------------------
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=

# ------------------------------------------------------------------
# Finnhub (free tier) — company news / catalysts. Optional.
# Sign up: https://finnhub.io/register  (60 calls/min cap; this app
# budgets itself to stay under 30/min). Leave blank to hide the news
# panel.
# ------------------------------------------------------------------
FINNHUB_KEY=

# ------------------------------------------------------------------
# Yahoo Finance (unofficial, no key needed) — Canadian (.TO) quotes,
# fundamentals, ^VIX, CAD=X. Delayed ~15 min. Set DISABLE_YAHOO=1 to
# simulate Canadian/context data instead.
# ------------------------------------------------------------------
DISABLE_YAHOO=

# Force full simulation even if keys are present (useful for UI work).
FORCE_SIM=

# Backend port (frontend dev server proxies to this).
PORT=4400
